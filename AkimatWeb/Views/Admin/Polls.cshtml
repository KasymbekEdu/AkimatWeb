@model List<AkimatWeb.Domain.Models.Poll>
@{
    ViewData["Title"] = "Сауалнамалар";
    Layout = "_AdminLayout";
}

<div style="display:flex;justify-content:space-between;margin-bottom:20px">
    <span style="color:#9ca3af">Барлығы: @Model.Count</span>
    <a asp-action="CreatePoll" class="btn btn-primary btn-sm">➕ Сауалнама қосу</a>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr><th>#</th><th>Сұрақ</th><th>Дауыс</th><th>Белсенді</th><th>Әрекет</th></tr>
        </thead>
        <tbody>
            @foreach (var poll in Model)
            {
                int voters = poll.Votes.Select(v => v.VoterFingerprint).Distinct().Count();
                <tr>
                    <td>@poll.Id</td>
                    <td style="max-width:300px;font-weight:500">@poll.Question</td>
                    <td><strong>@voters</strong> <span style="color:#9ca3af;font-size:0.8rem">қатысушы</span></td>
                    <td>
                        <form asp-action="TogglePoll" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@poll.Id" />
                            <button type="submit"
                                    class="badge @(poll.IsActive ? "badge-success" : "badge-secondary")"
                                    style="border:none;cursor:pointer;padding:4px 10px">
                                @(poll.IsActive ? "✅ Белсенді" : "⛔ Өшірілген")
                            </button>
                        </form>
                    </td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <a asp-controller="Polls" asp-action="Details" asp-route-id="@poll.Id"
                               target="_blank" class="btn btn-sm btn-outline">👁</a>
                            <form asp-action="DeletePoll" method="post" style="display:inline">
                                <input type="hidden" name="id" value="@poll.Id" />
                                <button type="submit" class="btn btn-sm btn-danger"
                                        data-confirm="Барлық нәтижелермен жойғыңыз келеді ме?">
                                    🗑
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>