@model AkimatWeb.Domain.Models.News
@{
    ViewData["Title"] = "Жаңалық қосу";
    Layout = "_AdminLayout";
    bool isEdit = Model.Id > 0;
}

<div style="max-width:780px">
    <div class="form-card">
        <h2 style="margin-bottom:24px;font-size:1.1rem">
            @(isEdit ? "✏ Жаңалықты өзгерту" : "➕ Жаңа жаңалық")
        </h2>

        <form asp-action="@(isEdit ? "EditNews" : "CreateNews")" method="post"
              enctype="multipart/form-data">
            @if (isEdit)
            {
                <input type="hidden" asp-for="Id"/>
                <input type="hidden" asp-for="ImagePath"/>
                <input type="hidden" asp-for="PublishedAt"/>
            }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Title" class="form-label">Тақырып *</label>
                <input asp-for="Title" class="form-control"
                       placeholder="Жаңалықтың тақырыбы..."/>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Суреттер (JPG, PNG, WEBP)</label>

                <input type="file"
                       name="images"
                       multiple
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.webp" />

                <small style="font-size:0.78rem;color:#9ca3af;margin-top:6px;display:block">
                    Бірнеше фото таңдауға болады.
                </small>
            </div>

            <div class="form-group">
                <label asp-for="Content" class="form-label">Мазмұны *</label>
                <textarea asp-for="Content" class="form-control" rows="12"
                          placeholder="Жаңалықтың толық мәтіні..."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:500">
                    <input asp-for="IsPublished" type="checkbox"
                           style="width:16px;height:16px;cursor:pointer"/>
                    Жарияланған (сайтта көрінеді)
                </label>
            </div>

            <div style="display:flex;gap:10px">
                <button type="submit" class="btn btn-primary">
                    💾 @(isEdit ? "Сақтау" : "Жарияла")
                </button>
                <a asp-action="News" class="btn btn-outline">Болдырмау</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
