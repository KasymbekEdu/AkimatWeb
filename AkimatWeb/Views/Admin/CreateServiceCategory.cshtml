@model AkimatWeb.Domain.Models.ServiceCategory
@{
    ViewData["Title"] = "Санат қосу";
    Layout = "_AdminLayout";
}

<div style="max-width:560px">
    <div class="form-card">
        <h2 style="margin-bottom:24px;font-size:1.1rem">➕ Жаңа санат</h2>
        <form asp-action="CreateServiceCategory" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="form-label">Санат атауы *</label>
                <input asp-for="Name" class="form-control" placeholder="мысалы: Азаматтық хал актілері"/>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="form-label">Сипаттама</label>
                <input asp-for="Description" class="form-control" placeholder="Қысқаша сипаттама..."/>
            </div>
            <div class="form-group">
                <label asp-for="SortOrder" class="form-label">Реттік нөмірі</label>
                <input asp-for="SortOrder" type="number" class="form-control" value="0"/>
            </div>
            <div style="display:flex;gap:10px">
                <button type="submit" class="btn btn-primary">💾 Сақтау</button>
                <a asp-action="Services" class="btn btn-outline">Болдырмау</a>
            </div>
        </form>
    </div>
</div>
