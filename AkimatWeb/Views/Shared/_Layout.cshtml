@using Microsoft.AspNetCore.Localization
@inject AkimatWeb.Infrastructure.AppConfig Config
<!DOCTYPE html>
<html lang="kk">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — @Config.Company.CompanyName</title>
    <meta name="description" content="@Config.Company.CompanyName — ресми сайт"/>
    <link rel="stylesheet" href="~/css/site.css"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Top bar -->
    @{
        var currentCulture = Context.Features
            .Get<IRequestCultureFeature>()?.RequestCulture.UICulture.Name ?? "kk-KZ";
        var isKk = currentCulture.StartsWith("kk");
    }

    <div class="top-bar">
        <div class="container">
            <span>📍 Қазақстан Республикасы</span>
        
            <span>
                <a href="tel:@Config.Company.CompanyPhoneShort">📞 @Config.Company.CompanyPhone</a>
                &nbsp;&nbsp;
                <a href="mailto:@Config.Company.CompanyEmail">✉ @Config.Company.CompanyEmail</a>
            </span>

            <!-- ТІЛ АУЫСТЫРУ -->
            <div style="display:flex;gap:4px;margin-left:12px">
                <form asp-controller="Language" asp-action="Switch" method="post">
                    <input type="hidden" name="culture" value="kk-KZ" />
                    <input type="hidden" name="returnUrl"
                           value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit"
                            style="background:@(isKk ? "rgba(255,255,255,0.25)" : "transparent");
                        border:1px solid rgba(255,255,255,0.4);
                        color:rgba(255,255,255,0.9);
                        padding:2px 10px;
                        border-radius:4px;
                        font-size:0.72rem;
                        font-weight:700;
                        cursor:pointer">
                        ҚАЗ
                    </button>
                </form>

                <form asp-controller="Language" asp-action="Switch" method="post">
                    <input type="hidden" name="culture" value="ru-RU" />
                    <input type="hidden" name="returnUrl"
                           value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit"
                            style="background:@(!isKk ? "rgba(255,255,255,0.25)" : "transparent");
                        border:1px solid rgba(255,255,255,0.4);
                        color:rgba(255,255,255,0.9);
                        padding:2px 10px;
                        border-radius:4px;
                        font-size:0.72rem;
                        font-weight:700;
                        cursor:pointer">
                        РУС
                    </button>
                </form>
            </div>

        </div>
    </div>

<!-- Navbar -->
<nav class="navbar">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <div class="logo-icon">Ә</div>
            <div>
                <span>@Config.Company.CompanyName</span>
                <small>Ресми интернет-ресурс</small>
            </div>
        </a>
        <button class="navbar-toggle" id="navToggle" aria-label="Мәзір">☰</button>
        <ul class="navbar-nav" id="mainNav">
            <li><a asp-controller="Home" asp-action="Index">Басты бет</a></li>
            <li><a asp-controller="News" asp-action="Index">Жаңалықтар</a></li>
            <li><a asp-controller="Announcements" asp-action="Index">Хабарландырулар</a></li>
                <li><a asp-controller="Map" asp-action="Index">🗺 Карта</a></li>
                <li><a asp-controller="Polls" asp-action="Index">📊 Сауалнамалар</a></li>
            <li><a asp-controller="Services" asp-action="Index">Қызметтер</a></li>
            <li><a asp-controller="Applications" asp-action="Submit">Өтініш беру</a></li>
            <li><a asp-controller="Home" asp-action="About">Әкімдік туралы</a></li>
            <li><a asp-controller="Home" asp-action="Contacts">Байланыс</a></li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                        <button type="submit" class="btn btn-sm" style="color:rgba(255,255,255,0.8);background:rgba(255,255,255,0.12);border:none;cursor:pointer;padding:8px 14px;border-radius:8px;">
                            Шығу
                        </button>
                    </form>
                </li>
            }
        </ul>
    </div>
</nav>

<!-- Page content -->
<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div>
                <h4>@Config.Company.CompanyName</h4>
                <p>Ресми интернет-ресурс. Барлық құқықтар қорғалған. Сайтта орналастырылған ақпаратты пайдалану кезінде сілтеме міндетті.</p>
                <br/>
                <p>📞 <a href="tel:@Config.Company.CompanyPhoneShort" style="color:rgba(255,255,255,0.65)">@Config.Company.CompanyPhone</a></p>
                <p>✉ <a href="mailto:@Config.Company.CompanyEmail" style="color:rgba(255,255,255,0.65)">@Config.Company.CompanyEmail</a></p>
            </div>
            <div>
                <h4>Навигация</h4>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Басты бет</a></li>
                    <li><a asp-controller="News" asp-action="Index">Жаңалықтар</a></li>
                    <li><a asp-controller="Announcements" asp-action="Index">Хабарландырулар</a></li>
                    <li><a asp-controller="Services" asp-action="Index">Мемлекеттік қызметтер</a></li>
                    <li><a asp-controller="Home" asp-action="About">Әкімдік туралы</a></li>
                </ul>
            </div>
            <div>
                <h4>Азаматтарға</h4>
                <ul class="footer-links">
                    <li><a asp-controller="Applications" asp-action="Submit">Өтініш беру</a></li>
                    <li><a asp-controller="Applications" asp-action="Track">Өтінішті тексеру</a></li>
                    <li><a asp-controller="Announcements" asp-action="Index" asp-route-type="Tender">Тендерлер</a></li>
                    <li><a asp-controller="Home" asp-action="Contacts">Байланыс</a></li>
                    <li><a href="https://egov.kz" target="_blank" rel="noopener">eGov.kz ↗</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="container">
            © @DateTime.Now.Year @Config.Company.CompanyName. Барлық құқықтар қорғалған.
        </div>
    </div>
</footer>

<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
