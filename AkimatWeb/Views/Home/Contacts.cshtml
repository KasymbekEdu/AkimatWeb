@inject IViewLocalizer Localizer
@inject AkimatWeb.Infrastructure.AppConfig Config
@{
    ViewData["Title"] = Localizer["ContactsTitle"].Value;
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
            <span>/</span>
            <span>@Localizer["ContactUS"]</span>
        </div>
        <h1>@Localizer["ContactsTitle"]</h1>
        <p>@Localizer["ContactsSubTitle"]</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="cards-grid cards-grid-3">
            <div class="form-card text-center">
                <div style="font-size:2rem;margin-bottom:12px">📞</div>
                <h3 style="margin-bottom:8px">@Localizer["Phone"]</h3>
                <p style="color:#4b5563">@Config.Company.CompanyPhone</p>
                <p style="font-size:0.82rem;color:#9ca3af;margin-top:6px">@Localizer["WorkingHoursValue"]</p>
            </div>
            <div class="form-card text-center">
                <div style="font-size:2rem;margin-bottom:12px">✉</div>
                <h3 style="margin-bottom:8px">@Localizer["Email"]</h3>
                <p><a href="mailto:@Config.Company.CompanyEmail">@Config.Company.CompanyEmail</a></p>
                <p style="font-size:0.82rem;color:#9ca3af;margin-top:6px">@Localizer["EmailReply"]</p>
            </div>
            <div class="form-card text-center">
                <div style="font-size:2rem;margin-bottom:12px">📍</div>
                <h3 style="margin-bottom:8px">@Localizer["Address"]</h3>
                <p style="color:#4b5563">@Localizer["AddressValue"]</p>
                <p style="font-size:0.82rem;color:#9ca3af;margin-top:6px">@Localizer["AppointmentNote"]</p>
            </div>
        </div>

        <div style="margin-top:40px;background:#f5f6f8;border-radius:12px;padding:32px;text-align:center">
            <h3 style="margin-bottom:12px">@Localizer["OnlineApp"]</h3>
            <p style="color:#4b5563;margin-bottom:20px">
                @Localizer["OnlineAppDesc"]
            </p>
            <a asp-controller="Applications" asp-action="Submit" class="btn btn-primary btn-lg">
                📝 @Localizer["SubmitBtn"]
            </a>
        </div>
    </div>
</section>
