@inject IViewLocalizer Localizer
@inject AkimatWeb.Infrastructure.AppConfig Config
@{
    ViewData["Title"] = Localizer["AboutTitle"].Value;
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
            <span>/</span>
            <span>@Localizer["About"]</span>
        </div>
        <h1>@Localizer["AboutTitle"]</h1>
        <p>@Config.Company.CompanyName</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div style="display:grid;grid-template-columns:2fr 1fr;gap:40px;align-items:start">
            <div>
                <h2 class="section-title">@Localizer["AboutUs"]</h2>
                <p style="margin-bottom:16px">
                    @Localizer["AboutDesc1"]
                </p>
                <p style="margin-bottom:16px">
                    @Localizer["AboutDesc2"]
                </p>

                <h3 style="margin:28px 0 16px">@Localizer["PriorityAreas"]</h3>
                <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">🏗</span>
                        <span>@Localizer["AreaInfra"]</span>
                    </li>
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">🌱</span>
                        <span>@Localizer["AreaEco"]</span>
                    </li>
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">👥</span>
                        <span>@Localizer["AreaSocial"]</span>
                    </li>
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">📚</span>
                        <span>@Localizer["AreaEducation"]</span>
                    </li>
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">💼</span>
                        <span>@Localizer["AreaBusiness"]</span>
                    </li>
                    <li style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f5f6f8;border-radius:8px">
                        <span style="font-size:1.2rem">🔒</span>
                        <span>@Localizer["AreaSafety"]</span>
                    </li>
                </ul>
            </div>
            <div>
                <div class="form-card" style="text-align:center">
                    <div style="font-size:3rem;margin-bottom:12px">🏛</div>
                    <h3 style="margin-bottom:16px">@Config.Company.CompanyName</h3>
                    <dl style="text-align:left">
                        <div class="detail-row">
                            <dt>@Localizer["Phone"]</dt>
                            <dd>@Config.Company.CompanyPhone</dd>
                        </div>
                        <div class="detail-row">
                            <dt>@Localizer["Email"]</dt>
                            <dd>@Config.Company.CompanyEmail</dd>
                        </div>
                        <div class="detail-row">
                            <dt>@Localizer["WorkingHours"]</dt>
                            <dd>@Localizer["WorkingHoursValue"]</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</section>
