@model HomeIndexVM
@{
    ViewData["Title"] = "Басты бет";
}

<!-- Hero -->
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1>Азаматтарға қызмет — біздің басты міндет</h1>
            <p>Өтініш беру, хабарландыруларды оқу, мемлекеттік қызметтерге қол жеткізу — бәрі осында.</p>
            <div class="hero-actions">
                <a asp-controller="Applications" asp-action="Submit" class="btn btn-white btn-lg">
                    📝 Өтініш беру
                </a>
                <a asp-controller="Applications" asp-action="Track" class="btn btn-gold btn-lg">
                    🔍 Өтінішті тексеру
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<div class="stats-bar">
    <div class="container">
        <div class="stat-item">
            <span class="stat-number">24/7</span>
            <span class="stat-label">Онлайн өтініш беру</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">3</span>
            <span class="stat-label">Жұмыс күні ішінде жауап</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">50+</span>
            <span class="stat-label">Мемлекеттік қызмет</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">0</span>
            <span class="stat-label">Делдалсыз, тікелей</span>
        </div>
    </div>
</div>

<!-- Latest News -->
@if (Model.LatestNews.Any())
{
    <section class="section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Соңғы жаңалықтар</h2>
                <a asp-controller="News" asp-action="Index" class="btn btn-outline btn-sm">Барлығы →</a>
            </div>
            <div class="cards-grid cards-grid-3">
                @foreach (var news in Model.LatestNews)
                {
                    <article class="card">
                        @if (!string.IsNullOrEmpty(news.ImagePath))
                        {
                            <img src="@news.ImagePath" alt="@news.Title" class="card-img"/>
                        }
                        else
                        {
                            <div class="card-img-placeholder">📰</div>
                        }
                        <div class="card-body">
                            <div class="card-meta">
                                <span>📅 @news.PublishedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                            <h3 class="card-title">
                                <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id">
                                    @news.Title
                                </a>
                            </h3>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id"
                               class="btn btn-outline btn-sm card-footer-link">
                                Толығырақ →
                            </a>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
}

<!-- Announcements -->
@if (Model.LatestAnnouncements.Any())
{
    <section class="section section-alt">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Хабарландырулар</h2>
                <a asp-controller="Announcements" asp-action="Index" class="btn btn-outline btn-sm">Барлығы →</a>
            </div>
            <div class="ann-list">
                @foreach (var ann in Model.LatestAnnouncements)
                {
                    <div class="ann-card type-@ann.Type">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
                            <div>
                                <span class="badge type-badge-@ann.Type" style="margin-bottom:6px;display:inline-block;">
                                    @(ann.Type switch {
                                        AnnouncementType.Tender => "Тендер",
                                        AnnouncementType.RoadClosure => "Жол жабылуы",
                                        AnnouncementType.Emergency => "Шұғыл",
                                        _ => "Жалпы"
                                    })
                                </span>
                                <h3 class="card-title" style="margin-bottom:0">
                                    <a asp-controller="Announcements" asp-action="Details" asp-route-id="@ann.Id">
                                        @ann.Title
                                    </a>
                                </h3>
                            </div>
                            <span class="text-muted" style="font-size:0.82rem;white-space:nowrap">
                                @ann.PublishedAt.ToString("dd.MM.yyyy")
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Services -->
@if (Model.ServiceCategories.Any())
{
    <section class="section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Мемлекеттік қызметтер</h2>
                <a asp-controller="Services" asp-action="Index" class="btn btn-outline btn-sm">Барлығы →</a>
            </div>
            <div class="cards-grid cards-grid-3">
                @foreach (var cat in Model.ServiceCategories)
                {
                    <a asp-controller="Services" asp-action="Details" asp-route-id="@cat.Id"
                       class="service-cat-card" style="text-decoration:none">
                        <div class="service-cat-icon">⚙</div>
                        <div class="service-cat-name">@cat.Name</div>
                        @if (!string.IsNullOrEmpty(cat.Description))
                        {
                            <p style="font-size:0.82rem;color:#9ca3af;margin-top:6px">@cat.Description</p>
                        }
                        <p style="font-size:0.8rem;color:#3b82f6;margin-top:10px">@cat.Services.Count қызмет →</p>
                    </a>
                }
            </div>
        </div>
    </section>
}

<!-- CTA: Submit application -->
<section class="section section-alt">
    <div class="container text-center">
        <h2 style="margin-bottom:12px">Мәселеңіз бар ма?</h2>
        <p style="color:#4b5563;margin-bottom:28px;max-width:480px;margin-left:auto;margin-right:auto">
            Өтінішіңізді онлайн жіберіңіз. Біз 3 жұмыс күні ішінде жауап береміз.
        </p>
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
            <a asp-controller="Applications" asp-action="Submit" class="btn btn-primary btn-lg">
                📝 Өтініш беру
            </a>
            <a asp-controller="Applications" asp-action="Track" class="btn btn-outline btn-lg">
                🔍 Өтінішті тексеру
            </a>
        </div>
    </div>
</section>
