@inject IViewLocalizer Localizer
@model HomeIndexVM

@{
    ViewData["Title"] = Localizer["HomePage"].Value;
}

<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1>@Localizer["HeroTitle"]</h1>
            <p>@Localizer["HeroSubTitle"]</p>
            <div class="hero-actions">
                <a asp-controller="Applications" asp-action="Submit" class="btn btn-white btn-lg">
                    📝 @Localizer["SubmitBtn"]
                </a>
                <a asp-controller="Applications" asp-action="Track" class="btn btn-gold btn-lg">
                    🔍 @Localizer["TrackBtn"]
                </a>
            </div>
        </div>
    </div>
</section>

<div class="stats-bar">
    <div class="container">
        <div class="stat-item">
            <span class="stat-number">24/7</span>
            <span class="stat-label">@Localizer["StatOnline"]</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">3</span>
            <span class="stat-label">@Localizer["StatDays"]</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">50+</span>
            <span class="stat-label">@Localizer["StatServices"]</span>
        </div>
        <div class="stat-item">
            <span class="stat-number">0</span>
            <span class="stat-label">@Localizer["StatDirect"]</span>
        </div>
    </div>
</div>

@if (Model.LatestNews.Any())
{
    <section class="section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">@Localizer["LatestNews"]</h2>
                <a asp-controller="News" asp-action="Index" class="btn btn-outline btn-sm">@Localizer["All"] →</a>
            </div>
            <div class="cards-grid cards-grid-3">
                @foreach (var news in Model.LatestNews)
                {
                    <article class="card">
                        @if (!string.IsNullOrEmpty(news.ImagePath))
                        {
                            <img src="@news.ImagePath" alt="@news.Title" class="card-img" />
                        }
                        else
                        {
                            <div class="card-img-placeholder">📰</div>
                        }
                        <div class="card-body">
                            <div class="card-meta">
                                <span>📅 @news.PublishedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                            <h3 class="card-title">
                                <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id">
                                    @news.Title
                                </a>
                            </h3>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id"
                                   class="btn btn-outline btn-sm card-footer-link">
                                @Localizer["More"] →
                            </a>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
}

@if (Model.LatestAnnouncements.Any())
{
    <section class="section section-alt">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">@Localizer["Announcements"]</h2>
                <a asp-controller="Announcements" asp-action="Index" class="btn btn-outline btn-sm">@Localizer["All"] →</a>
            </div>
            <div class="ann-list">
                @foreach (var ann in Model.LatestAnnouncements)
                {
                    <div class="ann-card type-@ann.Type">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
                            <div>
                                <span class="badge type-badge-@ann.Type" style="margin-bottom:6px;display:inline-block;">
                                    @(ann.Type switch
                                    {
                                        AnnouncementType.Tender => Localizer["Tender"].Value,
                                        AnnouncementType.RoadClosure => Localizer["RoadClosure"].Value,
                                        AnnouncementType.Emergency => Localizer["Emergency"].Value,
                                        _ => Localizer["General"].Value
                                    })
                                </span>
                                <h3 class="card-title" style="margin-bottom:0">
                                    <a asp-controller="Announcements" asp-action="Details" asp-route-id="@ann.Id">
                                        @ann.Title
                                    </a>
                                </h3>
                            </div>
                            <span class="text-muted" style="font-size:0.82rem;white-space:nowrap">
                                @ann.PublishedAt.ToString("dd.MM.yyyy")
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<section class="section">
    <div class="container text-center">
        <h2 style="margin-bottom:12px">@Localizer["CTATitle"]</h2>
        <p style="color:#4b5563;margin-bottom:28px;max-width:480px;margin-left:auto;margin-right:auto">
            @Localizer["CTASubTitle"]
        </p>
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
            <a asp-controller="Applications" asp-action="Submit" class="btn btn-primary btn-lg">
                📝 @Localizer["SubmitBtn"]
            </a>
            <a asp-controller="Applications" asp-action="Track" class="btn btn-outline btn-lg">
                🔍 @Localizer["TrackBtn"]
            </a>
        </div>
    </div>
</section>
