@inject IViewLocalizer Localizer
@model AkimatWeb.Domain.Models.Poll
@using AkimatWeb.Domain.Models
@{
    ViewData["Title"] = Model.Question;
    bool hasVoted = (bool)(ViewBag.HasVoted ?? false);
    var voteCounts = (Dictionary<int, int>)(ViewBag.VoteCounts ?? new Dictionary<int, int>());
    int totalVoters = (int)(ViewBag.TotalVotes ?? 0);
    bool isMulti = Model.Type == PollType.MultiChoice;
}

<div class="page-header">
    <div class="container">
        <h1>📊 @Localizer["PollsTitle"]</h1>
    </div>
</div>

<section class="section">
    <div class="container" style="max-width:640px">

        @if (TempData["VoteError"] is string err)
        {
            <div class="alert alert-danger">⚠ @err</div>
        }
        @if (TempData["VoteSuccess"] is string ok)
        {
            <div class="alert alert-success">✅ @ok</div>
        }

        <div class="form-card">
            <h2 style="font-size:1.1rem;margin-bottom:8px">@Model.Question</h2>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p style="color:#4b5563;margin-bottom:16px;font-size:0.9rem">@Model.Description</p>
            }
            <p style="font-size:0.82rem;color:#9ca3af;margin-bottom:20px">
                👥 @totalVoters @Localizer["Participants"]
                @if (isMulti)
                {
                    <span class="badge badge-info" style="margin-left:8px">@Localizer["MultiChoice"]</span>
                }
            </p>

            @if (hasVoted)
            {
                <p style="font-weight:600;color:#065f46;margin-bottom:16px">✅ @Localizer["VoteAccepted"] @Localizer["PollResults"]:</p>
                @foreach (var opt in Model.Options)
                {
                    int cnt = voteCounts.GetValueOrDefault(opt.Id, 0);
                    double pct = totalVoters > 0 ? (double)cnt / totalVoters * 100 : 0;
                    <div style="margin-bottom:12px">
                        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                            <span style="font-size:0.9rem;font-weight:500">@opt.Text</span>
                            <span style="font-size:0.8rem;color:#9ca3af">
                                @cnt (@pct.ToString("F1")%)
                            </span>
                        </div>
                        <div style="background:#e9ebee;border-radius:99px;height:10px">
                            <div style="height:100%;background:var(--blue);border-radius:99px;
                                width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%">
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <form asp-action="Vote" method="post">
                    <input type="hidden" name="pollId" value="@Model.Id" />
                    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px">
                        @foreach (var opt in Model.Options)
                        {
                            <label style="display:flex;align-items:center;gap:10px;
                                padding:12px 14px;border:1.5px solid #e9ebee;
                                border-radius:8px;cursor:pointer" class="poll-opt">
                                <input type="@(isMulti ? "checkbox" : "radio")"
                                       name="optionIds" value="@opt.Id"
                                       style="width:16px;height:16px;flex-shrink:0" />
                                @opt.Text
                            </label>
                        }
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">📤 @Localizer["VoteBtn"]</button>
                    <p style="font-size:0.75rem;color:#9ca3af;text-align:center;margin-top:8px">
                        @Localizer["AnonymousVote"]
                    </p>
                </form>
            }
        </div>
        <div style="margin-top:16px">
            <a asp-action="Index" class="btn btn-outline">← @Localizer["AllPolls"]</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.poll-opt').forEach(label => {
            const inp = label.querySelector('input');
            inp.addEventListener('change', () => {
                if (inp.type === 'radio')
                    document.querySelectorAll('.poll-opt').forEach(l => {
                        l.style.borderColor = '#e9ebee'; l.style.background = '';
                    });
                label.style.borderColor = inp.checked ? 'var(--blue)' : '#e9ebee';
                label.style.background  = inp.checked ? 'var(--blue-light)' : '';
            });
        });
    </script>
}
