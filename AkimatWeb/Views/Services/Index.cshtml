@inject IViewLocalizer Localizer
@model List<AkimatWeb.Domain.Models.ServiceCategory>
@{
    ViewData["Title"] = Localizer["ServicesTitle"].Value;
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
            <span>/</span><span>@Localizer["Services"]</span>
        </div>
        <h1>@Localizer["ServicesTitle"]</h1>
        <p>@Localizer["ServicesSubTitle"]</p>
    </div>
</div>

<section class="section">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">⚙</div>
                <p>@Localizer["NoServices"]</p>
            </div>
        }
        else
        {
            <div class="cards-grid cards-grid-3">
                @foreach (var cat in Model)
                {
                    <a asp-action="Details" asp-route-id="@cat.Id"
                           class="service-cat-card" style="text-decoration:none">
                        <div class="service-cat-icon">⚙</div>
                        <div class="service-cat-name">@cat.Name</div>
                        @if (!string.IsNullOrEmpty(cat.Description))
                        {
                            <p style="font-size:0.82rem;color:#9ca3af;margin-top:6px">@cat.Description</p>
                        }
                        <p style="font-size:0.8rem;color:#3b82f6;margin-top:12px">
                            @cat.Services.Count(s => s.IsActive) @Localizer["ServiceCount"] →
                        </p>
                    </a>
                }
            </div>
        }
    </div>
</section>
