@model AkimatWeb.Domain.Models.Announcement
@using AkimatWeb.Domain.Models
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Басты бет</a>
            <span>/</span>
            <a asp-controller="Announcements" asp-action="Index">Хабарландырулар</a>
            <span>/</span><span>Мәліметтер</span>
        </div>
        <h1>@Model.Title</h1>
        <p>📅 @Model.PublishedAt.ToString("dd.MM.yyyy")</p>
    </div>
</div>

<section class="section">
    <div class="container" style="max-width:800px">
        <div class="form-card">
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px">
                <span class="badge type-badge-@Model.Type">
                    @(Model.Type switch {
                        AnnouncementType.Tender      => "Тендер",
                        AnnouncementType.RoadClosure => "Жол жабылуы",
                        AnnouncementType.Emergency   => "🚨 Шұғыл",
                        _                            => "Жалпы"
                    })
                </span>
                @if (Model.ExpiresAt.HasValue)
                {
                    <span class="badge badge-warning">
                        ⏰ Мерзімі: @Model.ExpiresAt.Value.ToString("dd.MM.yyyy")
                    </span>
                }
            </div>
            <div style="line-height:1.8">@Html.Raw(Model.Content)</div>
        </div>
        <div style="margin-top:20px">
            <a asp-action="Index" class="btn btn-outline">← Хабарландыруларға қайту</a>
        </div>
    </div>
</section>
