@inject IViewLocalizer Localizer
@model List<AkimatWeb.Domain.Models.Announcement>
@using AkimatWeb.Domain.Models
@{
    ViewData["Title"] = Localizer["AnnPageTitle"].Value;
    AnnouncementType? currentType = ViewBag.CurrentType;
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
            <span>/</span><span>@Localizer["Announcements"]</span>
        </div>
        <h1>@Localizer["AnnPageTitle"]</h1>
    </div>
</div>

<section class="section">
    <div class="container">
        <div style="display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap">
            <a asp-action="Index"
               class="btn btn-sm @(currentType == null ? "btn-primary" : "btn-outline")">@Localizer["All"]</a>
            @foreach (var type in Enum.GetValues<AnnouncementType>())
            {
                var label = type switch
                {
                    AnnouncementType.Tender => Localizer["Tender"].Value,
                    AnnouncementType.RoadClosure => Localizer["RoadClosure"].Value,
                    AnnouncementType.Emergency => Localizer["Emergency"].Value,
                    _ => Localizer["General"].Value
                };
                <a asp-action="Index" asp-route-type="@type"
                   class="btn btn-sm @(currentType == type ? "btn-primary" : "btn-outline")">@label</a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📢</div>
                <p>@Localizer["NoAnnouncements"]</p>
            </div>
        }
        else
        {
            <div class="ann-list">
                @foreach (var ann in Model)
                {
                    <div class="ann-card type-@ann.Type">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap">
                            <div style="flex:1">
                                <div style="margin-bottom:6px">
                                    <span class="badge type-badge-@ann.Type">
                                        @(ann.Type switch
                                        {
                                            AnnouncementType.Tender => Localizer["Tender"].Value,
                                            AnnouncementType.RoadClosure => Localizer["RoadClosure"].Value,
                                            AnnouncementType.Emergency => "🚨 " + Localizer["Emergency"].Value,
                                            _ => Localizer["General"].Value
                                        })
                                    </span>
                                </div>
                                <h3 style="font-size:1rem;font-weight:600;margin-bottom:6px">
                                    <a asp-action="Details" asp-route-id="@ann.Id" style="color:#1f2937">
                                        @ann.Title
                                    </a>
                                </h3>
                                @if (ann.ExpiresAt.HasValue)
                                {
                                    <span style="font-size:0.78rem;color:#9ca3af">
                                        ⏰ @Localizer["Deadline"]: @ann.ExpiresAt.Value.ToString("dd.MM.yyyy")
                                    </span>
                                }
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
                                <span style="font-size:0.78rem;color:#9ca3af;white-space:nowrap">
                                    @ann.PublishedAt.ToString("dd.MM.yyyy")
                                </span>
                                <a asp-action="Details" asp-route-id="@ann.Id"
                                   class="btn btn-sm btn-outline">@Localizer["More"]</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
