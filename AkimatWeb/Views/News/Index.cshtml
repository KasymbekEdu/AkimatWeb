@inject IViewLocalizer Localizer
@model List<AkimatWeb.Domain.Models.News>
@{
    ViewData["Title"] = Localizer["NewsTitle"].Value;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<section class="section">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">@Localizer["NewsTitle"]</h1>
        </div>

        <!-- Іздеу -->
        <form method="get" style="margin-bottom:28px;display:flex;gap:10px;flex-wrap:wrap;">
            <input type="text" name="search" value="@ViewBag.Search"
                   placeholder="@Localizer["SearchNews"]"
                   style="flex:1;min-width:220px;padding:10px 14px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:0.97rem;" />
            <button type="submit" class="btn btn-primary">🔍</button>
        </form>

        @if (Model.Any())
        {
            <div class="cards-grid cards-grid-3">
                @foreach (var news in Model)
                {
                    <article class="card">
                        @if (!string.IsNullOrEmpty(news.ImagePath))
                        {
                            <img src="@news.ImagePath" alt="@news.Title" class="card-img" />
                        }
                        else
                        {
                            <div class="card-img-placeholder">📰</div>
                        }
                        <div class="card-body">
                            <div class="card-meta">
                                <span>📅 @news.PublishedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                            <h3 class="card-title">
                                <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id">
                                    @news.Title
                                </a>
                            </h3>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id"
                                   class="btn btn-outline btn-sm card-footer-link">
                                @Localizer["ReadMore"] →
                            </a>
                        </div>
                    </article>
                }
            </div>

            @if (totalPages > 1)
            {
                <div style="display:flex;justify-content:center;gap:8px;margin-top:36px;flex-wrap:wrap;">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search"
                               class="btn @(i == currentPage ? "btn-primary" : "btn-outline") btn-sm">
                            @i
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center" style="padding:48px 0;">@Localizer["NoNews"]</p>
        }
    </div>
</section>
